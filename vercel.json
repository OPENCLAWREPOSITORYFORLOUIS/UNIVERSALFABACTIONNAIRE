{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "cleanUrls": true,
  "functions": {
    "api/create-paydunya-payment.js": {
      "regions": ["cdg1"]
    },
    "api/paydunya-ipn.js": {
       "regions": ["cdg1"]
    }
  }
}
